@startuml
left to right direction
skinparam shadowing false
skinparam usecase {
  BackgroundColor #8b3ce0
  BorderColor #6d28d9
  FontColor white
  FontStyle bold
  FontSize 16
}
skinparam rectangle {
  BackgroundColor #ede3fd
  BorderColor #d4c2f9
  FontColor #3d1e7a
  FontSize 10
  RoundCorner 8
}
skinparam ArrowColor #555555
skinparam ArrowThickness 1.2
skinparam defaultTextAlignment center

rectangle "Ciclo de vida\nda viaxe" as C
rectangle "Gastos e\nliquidacións" as G
rectangle "Eventos e\ncalendario" as E
rectangle "Documentos\ncompartidos" as D

usecase "Telaria" as T

rectangle "Chat de\ngrupo" as CH
rectangle "Asistente\nde IA" as AI
rectangle "Rede de\namizades" as R

C -- T
G -- T
E -- T
D -- T
T -- CH
T -- AI
T -- R
@enduml
